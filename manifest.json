{
  "manifest_version": 3,
  "name": "SignWriting Keyboard",
  "version": "0.1.0",
  "description": "Type SignWriting in any input field tagged as a SignWriting field. Uses SignMaker as the on-screen keyboard.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": []
}
