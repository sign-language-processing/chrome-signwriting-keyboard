{
  "manifest_version": 3,
  "name": "SignWriting Keyboard",
  "version": "0.2.0",
  "description": "Type SignWriting in any input tagged as a SignWriting field. Opens SignMaker as an on-screen keyboard.",
  "author": "amit@nagish.com",
  "homepage_url": "https://github.com/sign-language-processing/chrome-signwriting-keyboard",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["vendor/font-ttf.min.js", "src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": [],
  "web_accessible_resources": [
    {
      "resources": ["vendor/fonts/*.ttf"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
